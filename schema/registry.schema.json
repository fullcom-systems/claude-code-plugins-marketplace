{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fullsys/claude-plugin-marketplace/schema/registry.schema.json",
  "title": "Plugin Registry",
  "description": "JSON Schema pro validaci registry.json v Claude Plugin Marketplace",
  "type": "object",
  "required": ["version", "updated", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "version",
          "description",
          "author",
          "tags",
          "types",
          "path",
          "distFile",
          "readme",
          "changelog"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "author": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["skill", "mcp", "mixed"]
            },
            "uniqueItems": true
          },
          "minClaudeVersion": {
            "type": ["string", "null"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "distFile": {
            "type": "string",
            "minLength": 1
          },
          "readme": {
            "type": "string",
            "minLength": 1
          },
          "changelog": {
            "type": "string",
            "minLength": 1
          },
          "mcpServers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "transport": {
                  "type": ["string", "null"],
                  "enum": ["stdio", "sse", "http", null]
                }
              }
            }
          }
        }
      }
    }
  }
}
